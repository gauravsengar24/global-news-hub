---
import { CATEGORIES } from '../lib/regions';
---

<footer class="bg-canvas text-ink-mute border-t border-hairline">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-10">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-flex items-center gap-1.5 type-body-md font-semibold text-ink mb-4" aria-label="MarketPulse Home">
          <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
          Market<span class="text-primary">Pulse</span>
        </a>
        <p class="type-caption text-ink-mute leading-relaxed max-w-xs">
          Real-time financial market news and analysis. Covering global stock markets, commodities, ETFs, mutual funds, forex, and economic indicators that move global markets.
        </p>
        <p class="type-micro text-ink-faint mt-4">
          Data sourced from publicly available RSS feeds.
          Not financial advice. Always do your own research.
        </p>
      </div>

      <div>
        <h4 class="type-micro font-bold text-ink uppercase tracking-wider mb-4">Markets</h4>
        <ul class="space-y-2">
          {[{code:'us',label:'🇺🇸 US Markets'},{code:'gb',label:'🇪🇺 UK & Europe'},{code:'in',label:'🇮🇳 India Markets'},{code:'jp',label:'🇯🇵 Japan Markets'},{code:'cn',label:'🇨🇳 China Markets'},{code:'au',label:'🇦🇺 Australia Markets'},{code:'em',label:'🌏 Emerging Markets'}].map(m => (
            <li><a href={`/region/${m.code}`} class="type-caption text-ink-mute hover:text-ink transition-colors">{m.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="type-micro font-bold text-ink uppercase tracking-wider mb-4">Sectors</h4>
        <ul class="space-y-2">
          {CATEGORIES.map(c => (
            <li><a href={`/category/${c.id}`} class="type-caption text-ink-mute hover:text-ink transition-colors">{c.icon} {c.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="type-micro font-bold text-ink uppercase tracking-wider mb-4">Data Feeds</h4>
        <ul class="space-y-2">
          <li><a href="/rss.xml" class="inline-flex items-center gap-1.5 type-caption text-primary hover:text-primary-deep transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93v-2.83z"/></svg>
            RSS Feed
          </a></li>
          <li><a href="/sitemap.xml" class="type-caption text-ink-mute hover:text-ink transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="type-micro text-ink-faint">
        &copy; {new Date().getFullYear()} MarketPulse. Updates every 30 minutes.
      </p>
      <div class="flex items-center gap-3 type-micro text-ink-faint">
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 bg-positive rounded-full" aria-hidden="true"></span> Market Open</span>
        <span aria-hidden="true">·</span>
        <span>Powered by open financial data</span>
      </div>
    </div>
  </div>
</footer>
