---
import { CATEGORIES } from '../lib/regions';
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-block text-xl font-bold text-white mb-3">
          GlobalNews <span class="text-blue-400">Hub</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Your trusted source for breaking news from around the world. Covering US, UK, India, Japan, China, Australia, and Europe.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Regions</h3>
        <ul class="space-y-2">
          <li><a href="/region/us" class="text-sm text-gray-400 hover:text-white transition-colors">🇺🇸 United States</a></li>
          <li><a href="/region/gb" class="text-sm text-gray-400 hover:text-white transition-colors">🇬🇧 United Kingdom</a></li>
          <li><a href="/region/in" class="text-sm text-gray-400 hover:text-white transition-colors">🇮🇳 India</a></li>
          <li><a href="/region/jp" class="text-sm text-gray-400 hover:text-white transition-colors">🇯🇵 Japan</a></li>
          <li><a href="/region/cn" class="text-sm text-gray-400 hover:text-white transition-colors">🇨🇳 China</a></li>
          <li><a href="/region/au" class="text-sm text-gray-400 hover:text-white transition-colors">🇦🇺 Australia</a></li>
          <li><a href="/region/eu" class="text-sm text-gray-400 hover:text-white transition-colors">🇪🇺 Europe</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Categories</h3>
        <ul class="space-y-2">
          {CATEGORIES.slice(0, 6).map(c => (
            <li><a href={`/category/${c.id}`} class="text-sm text-gray-400 hover:text-white transition-colors">{c.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Follow Us</h3>
        <p class="text-sm text-gray-400 mb-3">Get the latest news delivered to your feed.</p>
        <a href="/rss.xml" class="inline-flex items-center gap-2 text-sm text-orange-400 hover:text-orange-300 transition-colors font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93v-2.83z"/></svg>
          RSS Feed
        </a>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500">
        &copy; {new Date().getFullYear()} Global News Hub. All rights reserved.
        News content is sourced from publicly available RSS feeds and APIs.
      </p>
      <div class="flex items-center gap-4 text-xs text-gray-500">
        <span>Updated continuously</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>Powered by open news sources</span>
      </div>
    </div>
  </div>
</footer>