---
import { formatDate, timeAgo } from '../lib/regions';
export interface Props {
  article: {
    id: string;
    title: string;
    description: string;
    url: string;
    image: string;
    publishedAt: string;
    source: string;
    region: string;
    category: string;
  };
  featured?: boolean;
}

const { article, featured } = Astro.props;
const hostname = article.url ? new URL(article.url).hostname.replace('www.', '') : article.source;
const regionLabels = {
  us: 'US', gb: 'UK', in: 'IN', jp: 'JP', cn: 'CN', au: 'AU', eu: 'EU',
};
---

<article class:list={[
  'group bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5',
  featured ? 'lg:col-span-2 lg:row-span-2' : '',
]}>
  <a href={article.url} target="_blank" rel="noopener noreferrer" class="block h-full">
    <div class="relative overflow-hidden bg-gray-100">
      {
        article.image ? (
          <img
            src={article.image}
            alt={article.title}
            class:list={[
              'w-full object-cover transition-transform duration-500 group-hover:scale-105',
              featured ? 'h-72 sm:h-96 lg:h-[28rem]' : 'h-48 sm:h-56',
            ]}
            loading="lazy"
          />
        ) : (
          <div class:list={[
            'flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 text-gray-400',
            featured ? 'h-72 sm:h-96 lg:h-[28rem]' : 'h-48 sm:h-56',
          ]}>
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
        )
      }
      <div class="absolute top-3 left-3 flex gap-2">
        <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-white/90 text-gray-800 backdrop-blur-sm shadow-sm">
          {article.category}
        </span>
        <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-blue-600/90 text-white backdrop-blur-sm shadow-sm">
          {regionLabels[article.region] || article.region?.toUpperCase() || 'WW'}
        </span>
      </div>
      {featured && (
        <div class="absolute bottom-3 left-3">
          <span class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-full bg-red-600 text-white shadow-lg">
            Breaking News
          </span>
        </div>
      )}
    </div>
    <div class="p-4 sm:p-5">
      <div class="flex items-center gap-3 text-xs text-gray-500 mb-2">
        <span class="font-medium text-blue-600 truncate">{hostname}</span>
        <span class="w-1 h-1 rounded-full bg-gray-300"></span>
        <time datetime={article.publishedAt}>{timeAgo(article.publishedAt)}</time>
      </div>
      <h3 class:list={[
        'font-bold text-gray-900 leading-snug line-clamp-2 group-hover:text-blue-600 transition-colors',
        featured ? 'text-xl sm:text-2xl lg:text-3xl' : 'text-base sm:text-lg',
      ]}>
        {article.title}
      </h3>
      <p class="mt-2 text-sm text-gray-600 line-clamp-2 leading-relaxed">
        {article.description}
      </p>
    </div>
  </a>
</article>

<style is:global>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>