---
import { CATEGORIES, formatDate } from '../lib/regions';
import type { Article } from '../lib/types';

export interface Props {
  articles: Article[];
  title?: string;
}
const { articles, title } = Astro.props;
const latestArticles = articles.slice(0, 5);
const categoryCounts: Record<string, number> = {};
CATEGORIES.forEach(c => categoryCounts[c.id] = articles.filter(a => a.category === c.id).length);
const regionCounts: Record<string, number> = {};
articles.forEach(a => { regionCounts[a.region] = (regionCounts[a.region] || 0) + 1; });
const chartArticles = articles.slice(6, 10);
---

<aside class="space-y-4">
  {title && (
    <div class="flex items-center gap-2 mb-1">
      <h2 class="text-sm font-bold text-market-dark uppercase tracking-wider">{title}</h2>
      <div class="flex-1 h-px bg-market-border"></div>
    </div>
  )}

  <!-- Latest Headlines -->
  <div class="bg-white rounded-lg border border-market-border overflow-hidden">
    <div class="px-4 py-3 border-b border-market-border">
      <h3 class="text-xs font-bold text-market-dark uppercase tracking-wider">Latest Headlines</h3>
    </div>
    <div class="divide-y divide-market-border">
      {latestArticles.map((article) => (
        <a href={article.url} target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 hover:bg-market-bg transition-colors">
          <h4 class="text-[13px] font-medium text-market-dark line-clamp-2 leading-snug">{article.title}</h4>
          <time class="text-[11px] text-market-text-muted mt-0.5 block">{formatDate(article.publishedAt)}</time>
        </a>
      ))}
    </div>
  </div>

  <!-- Trending Stories -->
  {chartArticles.length > 0 && (
    <div class="bg-white rounded-lg border border-market-border overflow-hidden">
      <div class="px-4 py-3 border-b border-market-border">
        <h3 class="text-xs font-bold text-market-dark uppercase tracking-wider">Trending Now</h3>
      </div>
      <div class="divide-y divide-market-border">
        {chartArticles.map((article, i) => (
          <a href={article.url} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 px-4 py-2.5 hover:bg-market-bg transition-colors">
            <span class="flex-none w-5 h-5 rounded bg-market-dark text-white text-[10px] font-bold flex items-center justify-center mt-0.5">{i + 1}</span>
            <span class="text-[13px] font-medium text-market-dark line-clamp-2">{article.title}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Sectors -->
  <div class="bg-white rounded-lg border border-market-border overflow-hidden">
    <div class="px-4 py-3 border-b border-market-border">
      <h3 class="text-xs font-bold text-market-dark uppercase tracking-wider">Sectors</h3>
    </div>
    <div class="p-2">
      {CATEGORIES.map((cat) => (
        <a href={`/category/${cat.id}`} class="flex items-center justify-between px-3 py-2 rounded-md text-[13px] text-market-text-secondary hover:bg-market-bg hover:text-market-dark transition-colors">
          <span>{cat.icon} {cat.name}</span>
          <span class="text-[11px] text-market-text-muted bg-market-bg px-1.5 py-0.5 rounded">{categoryCounts[cat.id] || 0}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Markets by Region -->
  <div class="bg-white rounded-lg border border-market-border overflow-hidden">
    <div class="px-4 py-3 border-b border-market-border">
      <h3 class="text-xs font-bold text-market-dark uppercase tracking-wider">Markets</h3>
    </div>
    <div class="p-2">
      {Object.entries({ us: '🇺🇸 US', gb: '🇪🇺 Europe', in: '🇮🇳 India', jp: '🇯🇵 Japan', cn: '🇨🇳 China', au: '🇦🇺 Australia', em: '🌏 Emerging' }).map(([code, label]) => (
        <a href={`/region/${code}`} class="flex items-center justify-between px-3 py-2 rounded-md text-[13px] text-market-text-secondary hover:bg-market-bg hover:text-market-dark transition-colors">
          <span>{label}</span>
          <span class="text-[11px] text-market-text-muted bg-market-bg px-1.5 py-0.5 rounded">{regionCounts[code] || 0}</span>
        </a>
      ))}
    </div>
  </div>
</aside>