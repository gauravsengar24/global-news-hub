---
import { CATEGORIES, formatDate } from '../lib/regions';
import type { Article } from '../lib/types';

export interface Props {
  articles: Article[];
  title?: string;
}
const { articles, title } = Astro.props;
const latestArticles = articles.slice(0, 5);
const categoryCounts: Record<string, number> = {};
CATEGORIES.forEach(c => categoryCounts[c.id] = articles.filter(a => a.category === c.id).length);
const regionCounts: Record<string, number> = {};
articles.forEach(a => { regionCounts[a.region] = (regionCounts[a.region] || 0) + 1; });
const chartArticles = articles.slice(6, 10);
---

<aside class="space-y-6" aria-label="Sidebar">
  {title && (
    <div class="type-kicker tracking-[0.12em]">{title}</div>
  )}

  <!-- Latest Headlines -->
  <section>
    <h3 class="type-kicker mb-3">Latest</h3>
    <div class="space-y-3">
      {latestArticles.map((article) => (
        <a href={article.url} target="_blank" rel="noopener noreferrer" class="block group">
          <h4 class="type-caption font-medium text-ink leading-snug group-hover:text-primary transition-colors line-clamp-2">{article.title}</h4>
          <time class="type-micro text-ink-faint mt-0.5 block">{formatDate(article.publishedAt)}</time>
        </a>
      ))}
    </div>
  </section>

  <div class="h-px bg-hairline" aria-hidden="true"></div>

  <!-- Trending Stories -->
  {chartArticles.length > 0 && (
    <section>
      <h3 class="type-kicker mb-3">Trending</h3>
      <ol class="space-y-2.5">
        {chartArticles.map((article, i) => (
          <li>
            <a href={article.url} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group">
              <span class="flex-none w-5 h-5 rounded bg-ink/10 text-ink-mute type-micro font-bold flex items-center justify-center mt-0.5" aria-hidden="true">{i + 1}</span>
              <span class="type-caption font-medium text-ink leading-snug group-hover:text-primary transition-colors line-clamp-2">{article.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

  <div class="h-px bg-hairline" aria-hidden="true"></div>

  <!-- Sectors -->
  <section>
    <h3 class="type-kicker mb-3">Sectors</h3>
    <div class="space-y-1">
      {CATEGORIES.map((cat) => (
        <a href={`/category/${cat.id}`} class="flex items-center justify-between py-1 type-caption text-ink-mute hover:text-ink transition-colors">
          <span>{cat.icon} {cat.name}</span>
          <span class="type-micro text-ink-faint">{categoryCounts[cat.id] || 0}</span>
        </a>
      ))}
    </div>
  </section>

  <div class="h-px bg-hairline" aria-hidden="true"></div>

  <!-- Markets by Region -->
  <section>
    <h3 class="type-kicker mb-3">Markets</h3>
    <div class="space-y-1">
      {Object.entries({ us: '🇺🇸 US', gb: '🇪🇺 Europe', in: '🇮🇳 India', jp: '🇯🇵 Japan', cn: '🇨🇳 China', au: '🇦🇺 Australia', em: '🌏 Emerging' }).map(([code, label]) => (
        <a href={`/region/${code}`} class="flex items-center justify-between py-1 type-caption text-ink-mute hover:text-ink transition-colors">
          <span>{label}</span>
          <span class="type-micro text-ink-faint">{regionCounts[code] || 0}</span>
        </a>
      ))}
    </div>
  </section>
</aside>
