---
import { CATEGORIES, formatDate } from '../lib/regions';
import type { Article } from '../lib/types';

export interface Props {
  articles: Article[];
  title?: string;
}
const { articles, title } = Astro.props;
const latestArticles = articles.slice(0, 5);
const categoryCounts: Record<string, number> = {};
CATEGORIES.forEach(c => categoryCounts[c.id] = articles.filter(a => a.category === c.id).length);
const regionCounts: Record<string, number> = {};
articles.forEach(a => { regionCounts[a.region] = (regionCounts[a.region] || 0) + 1; });
const chartArticles = articles.slice(6, 10);
---

<aside class="space-y-5" aria-label="Sidebar">
  {title && (
    <div class="flex items-center gap-2 mb-1">
      <div class="w-1 h-4 bg-primary rounded-full" aria-hidden="true"></div>
      <h2 class="type-caption font-bold text-ink uppercase tracking-wider">{title}</h2>
      <div class="flex-1 h-px bg-hairline" aria-hidden="true"></div>
    </div>
  )}

  <!-- Latest Headlines -->
  <section class="bg-canvas rounded-lg border border-hairline overflow-hidden">
    <div class="px-4 py-3 border-b border-hairline">
      <h3 class="type-micro font-bold text-ink uppercase tracking-wider">Latest Headlines</h3>
    </div>
    <div class="divide-y divide-hairline">
      {latestArticles.map((article) => (
        <a href={article.url} target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 hover:bg-canvas-soft transition-colors">
          <h4 class="type-caption font-medium text-ink line-clamp-2 leading-snug">{article.title}</h4>
          <time class="type-micro text-ink-faint mt-0.5 block">{formatDate(article.publishedAt)}</time>
        </a>
      ))}
    </div>
  </section>

  <!-- Trending Stories -->
  {chartArticles.length > 0 && (
    <section class="bg-canvas rounded-lg border border-hairline overflow-hidden">
      <div class="px-4 py-3 border-b border-hairline">
        <h3 class="type-micro font-bold text-ink uppercase tracking-wider">Trending Now</h3>
      </div>
      <ol class="divide-y divide-hairline">
        {chartArticles.map((article, i) => (
          <li>
            <a href={article.url} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 px-4 py-2.5 hover:bg-canvas-soft transition-colors">
              <span class="flex-none w-5 h-5 rounded bg-ink text-on-primary type-micro font-bold flex items-center justify-center mt-0.5" aria-hidden="true">{i + 1}</span>
              <span class="type-caption font-medium text-ink line-clamp-2">{article.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- Sectors -->
  <section class="bg-canvas rounded-lg border border-hairline overflow-hidden">
    <div class="px-4 py-3 border-b border-hairline">
      <h3 class="type-micro font-bold text-ink uppercase tracking-wider">Sectors</h3>
    </div>
    <div class="p-2">
      {CATEGORIES.map((cat) => (
        <a href={`/category/${cat.id}`} class="flex items-center justify-between px-3 py-2 rounded-md type-caption text-ink-mute hover:bg-canvas-soft hover:text-ink transition-colors">
          <span>{cat.icon} {cat.name}</span>
          <span class="type-micro text-ink-faint bg-canvas-soft px-1.5 py-0.5 rounded">{categoryCounts[cat.id] || 0}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Markets by Region -->
  <section class="bg-canvas rounded-lg border border-hairline overflow-hidden">
    <div class="px-4 py-3 border-b border-hairline">
      <h3 class="type-micro font-bold text-ink uppercase tracking-wider">Markets</h3>
    </div>
    <div class="p-2">
      {Object.entries({ us: '🇺🇸 US', gb: '🇪🇺 Europe', in: '🇮🇳 India', jp: '🇯🇵 Japan', cn: '🇨🇳 China', au: '🇦🇺 Australia', em: '🌏 Emerging' }).map(([code, label]) => (
        <a href={`/region/${code}`} class="flex items-center justify-between px-3 py-2 rounded-md type-caption text-ink-mute hover:bg-canvas-soft hover:text-ink transition-colors">
          <span>{label}</span>
          <span class="type-micro text-ink-faint bg-canvas-soft px-1.5 py-0.5 rounded">{regionCounts[code] || 0}</span>
        </a>
      ))}
    </div>
  </section>
</aside>
