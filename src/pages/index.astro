---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import NewsCard from '../components/NewsCard.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { REGIONS, formatDate, MARKET_INDICES, CATEGORIES } from '../lib/regions';
import type { Article } from '../lib/types';

const { default: articles } = await import('../data/articles.json');
const { default: meta } = await import('../data/meta.json');

const featuredArticles = articles.slice(0, 3);
const latestArticles = articles.slice(3, 15);
const stocksArticles = articles.filter((a: Article) => a.category === 'stocks').slice(0, 4);
const commoditiesArticles = articles.filter((a: Article) => a.category === 'commodities').slice(0, 4);
const etfArticles = articles.filter((a: Article) => a.category === 'etf' || a.category === 'mutual-funds').slice(0, 4);
const economyArticles = articles.filter((a: Article) => a.category === 'economy').slice(0, 4);
const forexArticles = articles.filter((a: Article) => a.category === 'forex').slice(0, 3);

const regionArticles: Record<string, Article[]> = {};
Object.keys(REGIONS).forEach(code => {
  regionArticles[code] = articles.filter((a: Article) => a.region === code).slice(0, 3);
});
---

<Base>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Market Indices Summary -->
  <section class="bg-white border-b border-market-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex items-center gap-1 mb-2.5">
        <span class="text-[11px] font-bold uppercase text-market-text-muted tracking-wider">Market Summary</span>
        <span class="text-[11px] text-market-text-muted">· Updated {formatDate(meta.updatedAt)}</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2.5">
        <a href="/region/us" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">S&P 500</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">5,432.15</div>
          <div class="text-[11px] font-semibold text-positive">▲ +0.84%</div>
        </a>
        <a href="/region/us" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">NASDAQ</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">17,145.63</div>
          <div class="text-[11px] font-semibold text-positive">▲ +1.22%</div>
        </a>
        <a href="/region/us" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">Dow Jones</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">38,987.42</div>
          <div class="text-[11px] font-semibold text-positive">▲ +0.65%</div>
        </a>
        <a href="/region/gb" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">FTSE 100</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">8,214.56</div>
          <div class="text-[11px] font-semibold text-negative">▼ -0.32%</div>
        </a>
        <a href="/region/in" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">Nifty 50</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">25,012.30</div>
          <div class="text-[11px] font-semibold text-positive">▲ +0.92%</div>
        </a>
        <a href="/region/us" class="bg-market-bg rounded-lg px-3 py-2.5 hover:bg-gray-100 transition-colors">
          <div class="text-[11px] text-market-text-muted font-medium">Bitcoin</div>
          <div class="text-sm font-bold text-market-dark mt-0.5">$68,432</div>
          <div class="text-[11px] font-semibold text-positive">▲ +2.34%</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured + Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <div class="lg:col-span-3 space-y-6">
        <!-- Featured Hero -->
        {featuredArticles.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <NewsCard article={featuredArticles[0]} featured={true} />
            </div>
            {featuredArticles.slice(1).map(a => (
              <NewsCard article={a} horizontal={true} />
            ))}
          </div>
        )}

        <!-- Latest -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-base font-bold text-market-dark">Latest News</h2>
            <div class="flex-1 h-px bg-market-border"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
            {latestArticles.map((article) => (<NewsCard article={article} />))}
          </div>
        </div>

        <!-- Stocks -->
        {stocksArticles.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <h2 class="text-base font-bold text-market-dark">🏢 Stocks</h2>
              <div class="flex-1 h-px bg-market-border"></div>
              <a href="/category/stocks" class="text-[12px] text-market-blue hover:underline font-medium">More →</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
              {stocksArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </div>
        )}

        <!-- Commodities + Economy dual layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {commoditiesArticles.length > 0 && (
            <div>
              <div class="flex items-center gap-3 mb-3">
                <h2 class="text-base font-bold text-market-dark">🛢️ Commodities</h2>
                <div class="flex-1 h-px bg-market-border"></div>
                <a href="/category/commodities" class="text-[12px] text-market-blue hover:underline font-medium">More →</a>
              </div>
              <div class="space-y-3">
                {commoditiesArticles.slice(0, 3).map((article) => (<NewsCard article={article} horizontal={true} />))}
              </div>
            </div>
          )}
          {economyArticles.length > 0 && (
            <div>
              <div class="flex items-center gap-3 mb-3">
                <h2 class="text-base font-bold text-market-dark">📈 Economy</h2>
                <div class="flex-1 h-px bg-market-border"></div>
                <a href="/category/economy" class="text-[12px] text-market-blue hover:underline font-medium">More →</a>
              </div>
              <div class="space-y-3">
                {economyArticles.slice(0, 3).map((article) => (<NewsCard article={article} horizontal={true} />))}
              </div>
            </div>
          )}
        </div>

        <!-- ETFs -->
        {etfArticles.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <h2 class="text-base font-bold text-market-dark">📦 ETFs & Mutual Funds</h2>
              <div class="flex-1 h-px bg-market-border"></div>
              <a href="/category/etf" class="text-[12px] text-market-blue hover:underline font-medium">More →</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
              {etfArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </div>
        )}

        <!-- Forex -->
        {forexArticles.length > 0 && (
          <div>
            <div class="flex items-center gap-3 mb-3">
              <h2 class="text-base font-bold text-market-dark">💱 Forex</h2>
              <div class="flex-1 h-px bg-market-border"></div>
              <a href="/category/forex" class="text-[12px] text-market-blue hover:underline font-medium">More →</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {forexArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </div>
        )}

        <!-- Markets by Region -->
        <div>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-base font-bold text-market-dark">Global Markets</h2>
            <div class="flex-1 h-px bg-market-border"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {Object.entries(REGIONS).map(([code, region]) => {
              const arts = regionArticles[code] || [];
              if (arts.length === 0) return null;
              return (
                <a href={`/region/${code}`} class="bg-white rounded-lg border border-market-border overflow-hidden hover:shadow-md transition-shadow">
                  <div class="px-4 py-3 border-b border-market-border flex items-center justify-between">
                    <h3 class="text-sm font-bold text-market-dark">{region.flag} {region.name}</h3>
                    <svg class="w-3.5 h-3.5 text-market-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div class="divide-y divide-market-border">
                    {arts.slice(0, 3).map((article) => (
                      <div class="px-4 py-2.5 hover:bg-market-bg">
                        <h4 class="text-[13px] font-medium text-market-dark line-clamp-2 leading-snug">{article.title}</h4>
                        <span class="text-[11px] text-market-text-muted mt-0.5 block">{formatDate(article.publishedAt)}</span>
                      </div>
                    ))}
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <Sidebar articles={articles} title="Market Pulse" />
      </div>
    </div>
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
