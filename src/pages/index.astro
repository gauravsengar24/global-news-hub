---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import NewsCard from '../components/NewsCard.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { REGIONS, formatDate, CATEGORIES } from '../lib/regions';
import type { Article } from '../lib/types';

const { default: articles } = await import('../data/articles.json');
const { default: meta } = await import('../data/meta.json');

const featuredArticles = articles.slice(0, 3);
const latestArticles = articles.slice(3, 15);
const stocksArticles = articles.filter((a: Article) => a.category === 'stocks').slice(0, 4);
const commoditiesArticles = articles.filter((a: Article) => a.category === 'commodities').slice(0, 4);
const etfArticles = articles.filter((a: Article) => a.category === 'etf' || a.category === 'mutual-funds').slice(0, 4);
const economyArticles = articles.filter((a: Article) => a.category === 'economy').slice(0, 4);
const forexArticles = articles.filter((a: Article) => a.category === 'forex').slice(0, 3);

const regionArticles: Record<string, Article[]> = {};
Object.keys(REGIONS).forEach(code => {
  regionArticles[code] = articles.filter((a: Article) => a.region === code).slice(0, 3);
});
---

<Base>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Editorial Hero -->
  <section class="relative overflow-hidden bg-primary">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,#c9b4fa_0%,#6d5bb0_30%,#1b1938_60%,#0e0c1f_100%)] animate-[hero-atmosphere_8s_ease-in-out_infinite]" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_80%_80%,rgba(201,180,250,0.15)_0%,transparent_60%)]" aria-hidden="true"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-28 sm:py-36 lg:py-44">
      <div class="max-w-3xl">
        <div class="type-micro font-semibold text-surface-violet-soft uppercase tracking-[0.15em] mb-4">Markets Open</div>
        <h1 class="type-display-xxl text-on-primary mb-4">
          Markets in<br/>
          <span class="text-surface-violet-soft">Motion</span>
        </h1>
        <p class="type-body-lg text-on-dark-mute max-w-xl">
          Real-time global market data and financial news. Stocks, commodities, currencies — what moves, why it matters.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-surface-violet-soft/30 to-transparent" aria-hidden="true"></div>
  </section>

  <!-- Market Data Ribbon -->
  <section id="markets" class="bg-canvas-soft border-b border-hairline" aria-label="Market Indices">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
      <div class="type-kicker mb-4">Indices &middot; Updated {formatDate(meta.updatedAt)}</div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-px bg-hairline">
        <a href="/region/us" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">S&P 500</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">5,432.15</div>
          <div class="type-micro font-semibold text-positive tabular-nums">▲ +0.84%</div>
        </a>
        <a href="/region/us" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">NASDAQ</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">17,145.63</div>
          <div class="type-micro font-semibold text-positive tabular-nums">▲ +1.22%</div>
        </a>
        <a href="/region/us" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">Dow Jones</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">38,987.42</div>
          <div class="type-micro font-semibold text-positive tabular-nums">▲ +0.65%</div>
        </a>
        <a href="/region/gb" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">FTSE 100</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">8,214.56</div>
          <div class="type-micro font-semibold text-negative tabular-nums">▼ -0.32%</div>
        </a>
        <a href="/region/in" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">Nifty 50</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">25,012.30</div>
          <div class="type-micro font-semibold text-positive tabular-nums">▲ +0.92%</div>
        </a>
        <a href="/region/us" class="bg-canvas px-4 py-3 hover:bg-canvas-soft transition-colors">
          <div class="type-micro text-ink-mute font-medium">Bitcoin</div>
          <div class="text-sm font-bold text-ink mt-0.5 tabular-nums" style="font-weight:540">$68,432</div>
          <div class="type-micro font-semibold text-positive tabular-nums">▲ +2.34%</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10 lg:gap-12">
      <div class="lg:col-span-3 space-y-12 sm:space-y-14">

        <!-- Featured Editorial -->
        {featuredArticles.length > 0 && (
          <section aria-label="Featured stories">
            <div class="type-kicker mb-4">Lead Stories</div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="md:col-span-2">
                <NewsCard article={featuredArticles[0]} featured={true} />
              </div>
              {featuredArticles.slice(1).map(a => (
                <NewsCard article={a} horizontal={true} />
              ))}
            </div>
          </section>
        )}

        <!-- Latest News -->
        <section id="latest" aria-label="Latest news">
          <div class="type-kicker mb-4">Latest</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            {latestArticles.slice(0, 6).map((article) => (<NewsCard article={article} />))}
          </div>
        </section>

        <!-- Stocks -->
        {stocksArticles.length > 0 && (
          <section aria-label="Stocks news">
            <div class="type-kicker mb-4">Stocks</div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
              {stocksArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </section>
        )}

        <!-- Commodities + Economy -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {commoditiesArticles.length > 0 && (
            <section aria-label="Commodities news">
              <div class="type-kicker mb-4">Commodities</div>
              <div class="space-y-4">
                {commoditiesArticles.slice(0, 3).map((article) => (<NewsCard article={article} horizontal={true} />))}
              </div>
              <a href="/category/commodities" class="inline-flex items-center gap-1 mt-3 type-micro text-primary hover:text-primary-deep font-medium transition-colors">View all &rarr;</a>
            </section>
          )}
          {economyArticles.length > 0 && (
            <section aria-label="Economy news">
              <div class="type-kicker mb-4">Economy</div>
              <div class="space-y-4">
                {economyArticles.slice(0, 3).map((article) => (<NewsCard article={article} horizontal={true} />))}
              </div>
              <a href="/category/economy" class="inline-flex items-center gap-1 mt-3 type-micro text-primary hover:text-primary-deep font-medium transition-colors">View all &rarr;</a>
            </section>
          )}
        </div>

        <!-- ETFs -->
        {etfArticles.length > 0 && (
          <section aria-label="ETFs and mutual funds news">
            <div class="type-kicker mb-4">ETFs &amp; Mutual Funds</div>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
              {etfArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </section>
        )}

        <!-- Forex -->
        {forexArticles.length > 0 && (
          <section aria-label="Forex news">
            <div class="type-kicker mb-4">Forex</div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
              {forexArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </section>
        )}

        <!-- Global Markets -->
        <section aria-label="Global markets">
          <div class="type-kicker mb-4">Global Markets</div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-px bg-hairline rounded-lg overflow-hidden">
            {Object.entries(REGIONS).map(([code, region]) => {
              const arts = regionArticles[code] || [];
              if (arts.length === 0) return null;
              return (
                <a href={`/region/${code}`} class="bg-canvas px-4 py-3.5 hover:bg-canvas-soft transition-colors">
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="type-micro font-semibold text-ink uppercase tracking-wider">{region.flag} {region.name}</h3>
                    <svg class="w-3 h-3 text-ink-faint" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div class="space-y-1.5">
                    {arts.slice(0, 3).map((article) => (
                      <div>
                        <h4 class="type-micro font-medium text-ink-mute leading-snug line-clamp-2">{article.title}</h4>
                      </div>
                    ))}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <Sidebar articles={articles} title="Market Pulse" />
      </div>
    </div>
  </div>

  <!-- Closing Teal Band -->
  <section class="bg-surface-teal-deep border-t border-surface-teal-mid/30">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 lg:py-28 text-center">
      <h2 class="type-display-lg text-on-primary mb-4 sm:mb-6">
        Stay Ahead of the Markets
      </h2>
      <p class="type-body-lg text-on-dark-mute max-w-xl mx-auto mb-8 sm:mb-10">
        Real-time financial news, market data, and analysis delivered to your feed. Always free.
      </p>
      <a href="#markets" class="inline-flex items-center gap-2 px-6 py-3 bg-canvas text-surface-teal-deep rounded-md type-button-md font-semibold hover:bg-canvas/90 transition-colors">
        Track Markets
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </a>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
