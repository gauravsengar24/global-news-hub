---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import NewsCard from '../components/NewsCard.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { REGIONS, formatDate, MARKET_INDICES } from '../lib/regions';
import type { Article } from '../lib/types';

const { default: articles } = await import('../data/articles.json');
const { default: meta } = await import('../data/meta.json');

const featuredArticles = articles.slice(0, 3);
const latestArticles = articles.slice(3, 21);
const regionArticles: Record<string, Article[]> = {};
Object.keys(REGIONS).forEach(code => {
  regionArticles[code] = articles.filter((a: Article) => a.region === code).slice(0, 4);
});
const commoditiesArticles = articles.filter((a: Article) => a.category === 'commodities').slice(0, 4);
const etfArticles = articles.filter((a: Article) => a.category === 'etf' || a.category === 'mutual-funds').slice(0, 4);
---

<Base>
  <Fragment slot="header"><Header /></Fragment>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 sm:pt-8 pb-4">
    <div class="flex items-center gap-3 mb-2">
      <div class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black text-gray-900 tracking-tight">Markets</h1>
      </div>
      <span class="text-xs text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">{meta.totalArticles || articles.length} stories</span>
    </div>
    <p class="text-sm text-gray-500 mb-6">Real-time financial market news covering stocks, commodities, ETFs, mutual funds, forex, and global economic impact</p>

    <!-- Featured -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-10">
      {featuredArticles.map((article) => (<NewsCard article={article} featured={true} />))}
    </div>
  </section>

  <!-- Main layout -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <div class="lg:col-span-3 space-y-10">
        <!-- Latest -->
        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-gray-900">Latest Market News</h2>
            <span class="text-xs text-gray-400">Updated {formatDate(meta.updatedAt)}</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-6">
            {latestArticles.map((article) => (<NewsCard article={article} />))}
          </div>
        </div>

        <!-- Commodities Spotlight -->
        {commoditiesArticles.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span>Commodities</span>
              <span class="text-xs font-normal text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{commoditiesArticles.length}</span>
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
              {commoditiesArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </div>
        )}

        <!-- ETFs & Mutual Funds -->
        {etfArticles.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span>ETFs & Mutual Funds</span>
              <span class="text-xs font-normal text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{etfArticles.length}</span>
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
              {etfArticles.map((article) => (<NewsCard article={article} />))}
            </div>
          </div>
        )}
      </div>

      <div class="lg:col-span-1">
        <Sidebar articles={articles} title="Market Overview" />
      </div>
    </div>
  </section>

  <!-- Region sections -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-xl font-bold text-gray-900 mb-6">Markets by Region</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {Object.entries(REGIONS).map(([code, region]) => {
        const arts = regionArticles[code] || [];
        if (arts.length === 0) return null;
        return (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
              <a href={`/region/${code}`} class="flex items-center justify-between group">
                <h3 class="font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">{region.flag} {region.name}</h3>
                <svg class="w-4 h-4 text-gray-400 group-hover:text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
            <ul class="divide-y divide-gray-50">
              {arts.slice(0, 4).map((article) => (
                <li>
                  <a href={article.url} target="_blank" rel="noopener noreferrer" class="block px-4 py-3 hover:bg-gray-50">
                    <h4 class="text-sm font-medium text-gray-700 line-clamp-2 leading-snug">{article.title}</h4>
                    <span class="text-xs text-gray-400 mt-1 block">{formatDate(article.publishedAt)}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
