---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import NewsCard from '../../components/NewsCard.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import { REGIONS, formatDate } from '../../lib/regions';
import type { Article } from '../../lib/types';

export function getStaticPaths() {
  return Object.entries(REGIONS).map(([code, region]) => ({
    params: { region: code },
    props: { regionCode: code, regionInfo: region },
  }));
}

const { regionCode, regionInfo } = Astro.props;
const { default: allArticles } = await import('../../data/articles.json');

const regionArticles = allArticles.filter((a: Article) => a.region === regionCode);
const featured = regionArticles.slice(0, 1);
const rest = regionArticles.slice(1, 25);
const pageTitle = `${regionInfo.name} Financial News - MarketPulse`;
const pageDesc = `Latest financial market news from ${regionInfo.name}. Track ${regionInfo.name} stocks, indices, and economic data.`;
---

<Base>
  <Fragment slot="header"><Header /></Fragment>

  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 pt-8 sm:pt-10 pb-16 sm:pb-20">
    <nav aria-label="Breadcrumb" class="mb-2">
      <ol class="flex items-center gap-2 type-micro text-ink-faint">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page" class="text-ink-mute font-medium">{regionInfo.flag} {regionInfo.name}</li>
      </ol>
    </nav>
    <div class="mb-8 sm:mb-10">
      <div class="type-kicker mb-2">{regionInfo.flag} Markets</div>
      <div class="flex items-center gap-3">
        <h1 class="type-display-xl text-ink">{regionInfo.name}</h1>
        <span class="type-micro text-ink-faint">{regionArticles.length} stories</span>
      </div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10 lg:gap-12">
      <div class="lg:col-span-3">
        {featured.length > 0 && <div class="mb-8"><NewsCard article={featured[0]} featured={true} /></div>}
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {rest.map((article) => (<NewsCard article={article} />))}
        </div>
        {rest.length === 0 && <div class="text-center py-16"><p class="type-body-lg text-ink-faint">No market news for this region yet.</p></div>}
      </div>
      <div class="lg:col-span-1">
        <Sidebar articles={allArticles} title="Global Markets" />
      </div>
    </div>
  </div>

  <!-- Closing Teal Band -->
  <section class="bg-surface-teal-deep border-t border-surface-teal-mid/30">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 text-center">
      <h2 class="type-display-lg text-on-primary mb-4 sm:mb-6">
        Stay Ahead of the Markets
      </h2>
      <p class="type-body-lg text-on-dark-mute max-w-xl mx-auto mb-8 sm:mb-10">
        Real-time financial news, market data, and analysis delivered to your feed.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-canvas text-surface-teal-deep rounded-md type-button-md font-semibold hover:bg-canvas/90 transition-colors">
        Track Markets
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </a>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
